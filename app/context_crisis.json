{
  "context_name": "Economic Crisis",
  "description": "Prioritize retention interventions during an economic crisis: keep employees that are hard to replace, have relevant tenure, at least medium performance, acceptable salary cost within their department, and medium/high commitment.",
  "rules": [
    {
      "name": "tenure_relevant",
      "feature": "years_at_company",
      "type": "triangular",
      "params": [3, 10, 20],
      "note": "Relevant tenure: not a newcomer, not too close to late-career stagnation."
    },
    {
      "name": "performance_at_least_medium",
      "feature": "performance_rating",
      "type": "linear_increasing",
      "params": [2, 4],
      "note": "Performance rating: 3 is not poor; 4 is ideal."
    },

    {
      "name": "joblevel_high",
      "feature": "job_level",
      "type": "linear_increasing",
      "params": [2, 5],
      "note": "Higher job level implies higher responsibility and harder replacement."
    },

    {
      "name": "jobrole_critical",
      "feature": "job_role",
      "type": "categorical_set",
      "params": {
        "critical": [
          "Research Director",
          "Manufacturing Director",
          "Manager"
        ],
        "important": [
          "Research Scientist",
          "Healthcare Representative"
        ],
        "standard": [
          "Sales Executive",
          "Laboratory Technician",
          "Human Resources",
          "Sales Representative"
        ]
      },
      "note": "Role criticality table. You can tune these sets."
    },

    {
      "name": "salary_cost_ok_hr",
      "feature": "monthly_income",
      "type": "triangular",
      "params": [3000, 6000, 9000],
      "when": { "feature": "department", "equals": "Human Resources" },
      "note": "HR salary cost acceptable range."
    },
    {
      "name": "salary_cost_ok_rd",
      "feature": "monthly_income",
      "type": "triangular",
      "params": [4000, 10000, 15000],
      "when": { "feature": "department", "equals": "Research & Development" },
      "note": "R&D salary cost acceptable range."
    },
    {
      "name": "salary_cost_ok_sales",
      "feature": "monthly_income",
      "type": "triangular",
      "params": [4000, 10000, 15000],
      "when": { "feature": "department", "equals": "Sales" },
      "note": "Sales salary cost acceptable range."
    },

    {
      "name": "involvement_medium",
      "feature": "job_involvement",
      "type": "triangular",
      "params": [1, 3, 4],
      "note": "Medium involvement around 3."
    },
    {
      "name": "involvement_high",
      "feature": "job_involvement",
      "type": "linear_increasing",
      "params": [2, 4],
      "note": "High involvement: grows to 1 at 4."
    },

    {
      "name": "satisfaction_medium",
      "feature": "job_satisfaction",
      "type": "triangular",
      "params": [1, 3, 4],
      "note": "Medium satisfaction around 3."
    },
    {
      "name": "satisfaction_high",
      "feature": "job_satisfaction",
      "type": "linear_increasing",
      "params": [2, 4],
      "note": "High satisfaction: grows to 1 at 4."
    }
  ],

  "derived_rules": [
    {
      "name": "hard_to_replace",
      "op": "OR",
      "inputs": [
        { "rule": "joblevel_high" },
        { "rule": "jobrole_critical", "map": { "critical": 1.0, "important": 0.7, "standard": 0.3 } }
      ],
      "note": "Hard-to-replace if job level is high OR role is critical."
    },
    {
      "name": "commitment_medium_or_high",
      "op": "OR",
      "inputs": [
        { "rule": "involvement_medium" },
        { "rule": "involvement_high" },
        { "rule": "satisfaction_medium" },
        { "rule": "satisfaction_high" }
      ],
      "note": "Commitment approximated as medium OR high involvement/satisfaction."
    },
    {
      "name": "salary_cost_ok",
      "op": "OR",
      "inputs": [
        { "rule": "salary_cost_ok_hr" },
        { "rule": "salary_cost_ok_rd" },
        { "rule": "salary_cost_ok_sales" }
      ],
      "note": "Select the salary membership depending on department."
    }
  ],

  "logic": {
    "op": "AND",
    "inputs": [
      { "rule": "hard_to_replace" },
      { "rule": "tenure_relevant" },
      { "rule": "performance_at_least_medium" },
      { "rule": "salary_cost_ok" },
      { "rule": "commitment_medium_or_high" }
    ],
    "aggregation": "product",
    "note": "Strict-ish conjunction: product penalizes low membership in any key criterion."
  }
}